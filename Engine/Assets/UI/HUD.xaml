                <!--
                    MasksContainer
                    ═══════════════════════════════════════════════════════════
                    3 slots posicionales. HUDController decide qué imagen
                    mostrar en cada slot según la máscara equipada y el orden
                    de obtención. Todos los Viewbox tienen x:Name propio.

                    Active (grande, arriba)     → máscara equipada actualmente
                    Left   (pequeño, abajo izq) → 1ª obtenida que no está en Active
                    Right  (pequeño, abajo der) → 2ª obtenida que no está en Active

                    Elementos controlados por Lua:
                      Active_Hermes  Active_Ares  Active_Apolo
                      Left_Hermes    Left_Ares    Left_Apolo
                      Right_Hermes   Right_Ares   Right_Apolo
                    ═══════════════════════════════════════════════════════════
                -->
                <Grid x:Name="MasksContainer" Width="234" HorizontalAlignment="Left" ClipToBounds="True">

                    <!-- SLOT GRANDE: máscara equipada -->
                    <Viewbox x:Name="Active_Hermes" Visibility="Collapsed" Margin="23,18,31,36">
                        <Image Source="Textures/Hermes.PNG" Width="47" Height="46"/>
                    </Viewbox>
                    <Viewbox x:Name="Active_Ares" Visibility="Collapsed" Margin="23,18,31,36">
                        <Image Source="Textures/Ares.PNG" Width="47" Height="46"/>
                    </Viewbox>
                    <Viewbox x:Name="Active_Apolo" Visibility="Collapsed" Margin="23,18,31,36">
                        <Image Source="Textures/Apolo.PNG" Width="47" Height="46"/>
                    </Viewbox>

                    <!-- SLOT PEQUEÑO IZQUIERDA: primera obtenida no equipada -->
