                    <Viewbox x:Name="Left_Apolo" Visibility="Collapsed" Margin="13,96,170,21">
                        <Image Source="Textures/Apolo.PNG" Width="40" Height="40" Opacity="0.6"/>
                    </Viewbox>

                    <!-- SLOT PEQUEÑO DERECHA: segunda obtenida no equipada -->
