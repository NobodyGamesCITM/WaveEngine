    <Grid x:Name="LayoutRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d"
    xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
    d:DesignWidth="1920" d:DesignHeight="1080">

        <Grid.RowDefinitions>
            <RowDefinition Height="298*"/>
            <RowDefinition Height="484*"/>
            <RowDefinition Height="298*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200*"/>
            <ColumnDefinition Width="746*"/>
            <ColumnDefinition Width="334*"/>
        </Grid.ColumnDefinitions>

        <!-- Fondo transparente (sin background visible, HUD overlay) -->
        <Grid.Background>
            <SolidColorBrush Color="#00000000"/>
        </Grid.Background>

        <!-- HealthBar: columna izquierda -->
        <Viewbox x:Name="HealtBar_Viewport" Grid.Row="0" Grid.Column="0" Stretch="Uniform">
            <Grid Width="50" Height="68" Margin="0,6,50,26">
                <Grid x:Name="HealthGrid" VerticalAlignment="Bottom" Width="28" Height="68" Margin="11,0">
                    <Rectangle x:Name="HealthFill" Width="28" Height="68" VerticalAlignment="Bottom">
                        <Rectangle.Fill>
                            <ImageBrush ImageSource="Textures/HealthBar_Interior.png"/>
                        </Rectangle.Fill>
                    </Rectangle>
                </Grid>
                <Image x:Name="HealthBar_Image" Margin="11,0" Source="Textures/Health_Bar.png"/>
            </Grid>
        </Viewbox>

        <!-- Imagen del jugador: columna central -->
        <Viewbox x:Name="PlayerImage_Viewport" Stretch="Uniform" Grid.Row="0">
            <Image x:Name="mask" Width="100" Height="100" Source="Textures/HUD_Player.png" Margin="-1,0,1,0"/>
        </Viewbox>

        <!-- StaminaBar: columna derecha -->
        <Viewbox x:Name="StaminaBar_Viewport" Grid.Row="0" Stretch="Uniform">
            <Grid Width="50" Height="68" Margin="50,6,0,26" RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <ScaleTransform ScaleX="-1"/>
                </Grid.RenderTransform>
                <Grid x:Name="StaminaGrid" Width="50" VerticalAlignment="Bottom" Margin="11,0,-11,0" Height="68">
                    <Rectangle x:Name="StaminaFill" Height="68" Width="28"
                            VerticalAlignment="Bottom" Margin="1,0,21,0">
                        <Rectangle.Fill>
                            <ImageBrush ImageSource="Textures/StaminaBar_Interior.png"/>
                        </Rectangle.Fill>
                    </Rectangle>
                </Grid>
                <Image x:Name="StaminaBar_Image" Source="Textures/Health_Bar.png" Margin="12,0,10,0"/>
            </Grid>
        </Viewbox>
        <Viewbox x:Name="UsedPotion_Viewport" Grid.Row="0" Stretch="Uniform" Grid.Column="2">
            <Grid RenderTransformOrigin="0.5,0.5" Height="68" Width="113">
                <Grid.RenderTransform>
                    <ScaleTransform ScaleX="-1"/>
                </Grid.RenderTransform>
                <Image x:Name="UsedPotion_Image4" Margin="12,15,82,34" Source="Textures/HealthPotion_Used.png"/>
                <Image x:Name="UsedPotion_Image3" Margin="31,15,63,34" Source="Textures/HealthPotion_Used.png"/>
                <Image x:Name="UsedPotion_Image2" Margin="50,15,44,34" Source="Textures/HealthPotion_Used.png"/>
                <Image x:Name="UsedPotion_Image1" Margin="69,15,25,34" Source="Textures/HealthPotion_Used.png"/>
            </Grid>
        </Viewbox>
        <Viewbox x:Name="Potion_Viewport" Grid.Row="0" Stretch="Uniform" Grid.Column="2">
            <Grid RenderTransformOrigin="0.5,0.5" Height="68" Width="113">
                <Grid.RenderTransform>
                    <ScaleTransform ScaleX="-1"/>
                </Grid.RenderTransform>
                <Image x:Name="Potion_Image4" Source="Textures/HealthPotion.png" Margin="12,15,82,34"/>
                <Image x:Name="Potion_Image3" Source="Textures/HealthPotion.png" Margin="31,15,63,34"/>
                <Image x:Name="Potion_Image2" Source="Textures/HealthPotion.png" Margin="50,15,44,34"/>
                <Image x:Name="Potion_Image1" Source="Textures/HealthPotion.png" Margin="69,15,25,34"/>
            </Grid>
        </Viewbox>

    </Grid>
