<Grid x:Name="LayoutRoot"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d"
xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
d:DesignWidth="1920" d:DesignHeight="1080">

    <Grid.Background>
        <SolidColorBrush Color="#00000000"/>
    </Grid.Background>

    <Viewbox Stretch="Uniform" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid Width="1920" Height="1080">

            <!-- HUD superior izquierda -->
            <Grid HorizontalAlignment="Left"
                  VerticalAlignment="Top"
                  Margin="20,20,0,0"
                  Width="500"
                  Height="168">

                <Image x:Name="HUD_Base" Source="Textures/MainHUD.PNG"
                       Width="500"
                       Height="168"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       Stretch="Fill"/>

                <Grid x:Name="HealthBarContainer" Margin="123,0,43,118"
                      HorizontalAlignment="Left"
                      ClipToBounds="True">
                    <Grid x:Name="HealthBarGrid"
                          HorizontalAlignment="Left"
                          Width="334">
                        <Image x:Name="HealthBar" Source="Textures/Health_Bar.PNG"
                               HorizontalAlignment="Left"
                               Stretch="Fill"/>
                    </Grid>
                </Grid>

                <Grid x:Name="StaminaBarContainer" Margin="163,54,86,93"
                      HorizontalAlignment="Left"
                      ClipToBounds="True">
                    <Grid x:Name="StaminaBarGrid"
                          HorizontalAlignment="Left"
                          Width="251">
                        <Image x:Name="StaminaBar" Source="Textures/Stamina_Bar.PNG"
                               HorizontalAlignment="Left"
                               Stretch="Fill"/>
                    </Grid>
                </Grid>

                <StackPanel x:Name="UsedPotionStackPanel" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center" Height="100" Width="200" Margin="177,59,0,0">
                    <Image x:Name="UsedPotion1" Source="Textures/Pocion_Used.PNG" Height="50" Width="50" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform Angle="25"/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                    <Image x:Name="UsedPotion2" Source="Textures/Pocion_Used.PNG" Height="50" Width="50" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform Angle="25"/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                    <Image x:Name="UsedPotion3" Source="Textures/Pocion_Used.PNG" Height="50" Width="50" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform Angle="25"/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                    <Image x:Name="UsedPotion4" Source="Textures/Pocion_Used.PNG" Height="50" Width="50" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform Angle="25"/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                </StackPanel>

                <StackPanel x:Name="PotionStackPanel" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center" Height="100" Width="200" Margin="177,59,0,0">
                    <Image x:Name="Potion1" Source="Textures/Pocion.PNG" Width="50" Height="50" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform Angle="25"/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                    <Image x:Name="Potion2" Source="Textures/Pocion.PNG" Width="50" Height="50" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform Angle="25"/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                    <Image x:Name="Potion3" Source="Textures/Pocion.PNG" Width="50" Height="50" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform Angle="25"/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                    <Image x:Name="Potion4" Source="Textures/Pocion.PNG" Width="50" Height="50" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform Angle="25"/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                </StackPanel>
                <Grid x:Name="MasksContainer" Width="234" HorizontalAlignment="Left" ClipToBounds="True">
                    <Viewbox x:Name="Mask_1">
                        <Image x:Name="Mask_1_Image" Source="Textures/Hermes.PNG" Width="47" Height="46" Margin="23,18,31,36"/>
                    </Viewbox>
                    <Viewbox x:Name="Mask_2" Margin="13,96,170,21">
                        <Image x:Name="Mask_2_Image" Source="Textures/Ares.PNG" Width="100" Height="100"/>
                    </Viewbox>
                    <Viewbox x:Name="Mask_3" Margin="163,92,14,19">
                        <Image x:Name="Mask_3_Image" Source="Textures/Apolo.PNG" Width="100" Height="100"/>
                    </Viewbox>
                </Grid>

            </Grid>

            <!-- Prompt de interacción: posición absoluta sobre el objeto -->
            <Canvas Width="1920" Height="1080"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top">
                <StackPanel x:Name="InteractPrompt"
                            Visibility="Collapsed"
                            Orientation="Horizontal"
                            Canvas.Left="0"
                            Canvas.Top="0">
                    <Border CornerRadius="6" Padding="20,8,20,8">
                        <Border.Background>
                            <SolidColorBrush Color="#CC000000"/>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="InputKeyBorder"
                                    CornerRadius="4"
                                    Padding="8,4,8,4"
                                    Margin="0,0,10,0">
                                <Border.Background>
                                    <SolidColorBrush Color="#FFFFFFFF"/>
                                </Border.Background>
                                <Grid>
                                    <TextBlock x:Name="InputKeyText"
                                               Text="F"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               FontFamily="Arial"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                                        <TextBlock.Foreground>
                                            <SolidColorBrush Color="#FF000000"/>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                    <Image x:Name="InputGamepadIcon"
                                           Source="Textures/inputA.png"
                                           Width="28" Height="28"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                            <TextBlock x:Name="InteractText"
                                       Text="Interactuar"
                                       FontSize="22"
                                       FontFamily="Arial"
                                       VerticalAlignment="Center">
                                <TextBlock.Foreground>
                                    <SolidColorBrush Color="#FFFFFFFF"/>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Canvas>

        </Grid>
    </Viewbox>

</Grid>