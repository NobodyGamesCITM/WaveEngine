<Grid x:Name="LayoutRoot"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d"
xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
d:DesignWidth="1920" d:DesignHeight="1080">

    <Grid.Background>
        <SolidColorBrush Color="#00000000"/>
    </Grid.Background>

    <Viewbox Stretch="Uniform" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid Width="1920" Height="1080">

            <!-- HUD superior izquierda -->
            <Grid HorizontalAlignment="Left"
                  VerticalAlignment="Top"
                  Margin="20,20,0,0"
                  Width="500"
                  Height="168">

                <Image x:Name="HUD_Base" Source="Textures/MainHUD.PNG"
                       Width="500" Height="168"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       Stretch="Fill"/>

                <Grid x:Name="HealthBarContainer" Margin="123,0,43,118"
                      HorizontalAlignment="Left"
                      ClipToBounds="True">
                    <Grid x:Name="HealthBarGrid"
                          HorizontalAlignment="Left"
                          Width="334">
                        <Image x:Name="HealthBar" Source="Textures/Health_Bar.PNG"
                               HorizontalAlignment="Left"
                               Stretch="Fill"/>
                    </Grid>
                </Grid>

                <Grid x:Name="StaminaBarContainer" Margin="163,54,86,93"
                      HorizontalAlignment="Left"
                      ClipToBounds="True">
                    <Grid x:Name="StaminaBarGrid"
                          HorizontalAlignment="Left"
                          Width="251">
                        <Image x:Name="StaminaBar" Source="Textures/Stamina_Bar.PNG"
                               HorizontalAlignment="Left"
                               Stretch="Fill"/>
                    </Grid>
                </Grid>

                <StackPanel x:Name="UsedPotionStackPanel" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Height="100" Width="200" Margin="177,59,0,0">
                    <Image x:Name="UsedPotion1" Source="Textures/Pocion_Used.PNG" Height="50" Width="50" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform><TransformGroup><ScaleTransform/><SkewTransform/><RotateTransform Angle="25"/><TranslateTransform/></TransformGroup></Image.RenderTransform>
                    </Image>
                    <Image x:Name="UsedPotion2" Source="Textures/Pocion_Used.PNG" Height="50" Width="50" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform><TransformGroup><ScaleTransform/><SkewTransform/><RotateTransform Angle="25"/><TranslateTransform/></TransformGroup></Image.RenderTransform>
                    </Image>
                    <Image x:Name="UsedPotion3" Source="Textures/Pocion_Used.PNG" Height="50" Width="50" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform><TransformGroup><ScaleTransform/><SkewTransform/><RotateTransform Angle="25"/><TranslateTransform/></TransformGroup></Image.RenderTransform>
                    </Image>
                    <Image x:Name="UsedPotion4" Source="Textures/Pocion_Used.PNG" Height="50" Width="50" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform><TransformGroup><ScaleTransform/><SkewTransform/><RotateTransform Angle="25"/><TranslateTransform/></TransformGroup></Image.RenderTransform>
                    </Image>
                </StackPanel>

                <StackPanel x:Name="PotionStackPanel" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Height="100" Width="200" Margin="177,59,0,0">
                    <Image x:Name="Potion1" Source="Textures/Pocion.PNG" Width="50" Height="50" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform><TransformGroup><ScaleTransform/><SkewTransform/><RotateTransform Angle="25"/><TranslateTransform/></TransformGroup></Image.RenderTransform>
                    </Image>
                    <Image x:Name="Potion2" Source="Textures/Pocion.PNG" Width="50" Height="50" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform><TransformGroup><ScaleTransform/><SkewTransform/><RotateTransform Angle="25"/><TranslateTransform/></TransformGroup></Image.RenderTransform>
                    </Image>
                    <Image x:Name="Potion3" Source="Textures/Pocion.PNG" Width="50" Height="50" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform><TransformGroup><ScaleTransform/><SkewTransform/><RotateTransform Angle="25"/><TranslateTransform/></TransformGroup></Image.RenderTransform>
                    </Image>
                    <Image x:Name="Potion4" Source="Textures/Pocion.PNG" Width="50" Height="50" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform><TransformGroup><ScaleTransform/><SkewTransform/><RotateTransform Angle="25"/><TranslateTransform/></TransformGroup></Image.RenderTransform>
                    </Image>
                </StackPanel>

            </Grid>

            <!-- Prompt de interacción -->
            <Canvas Width="1920" Height="1080"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top">
                <StackPanel x:Name="InteractPrompt"
                            Visibility="Collapsed"
                            Orientation="Horizontal"
                            Canvas.Left="0"
                            Canvas.Top="0">
                    <Border CornerRadius="6" Padding="16,8,16,8">
                        <Border.Background>
                            <SolidColorBrush Color="#CC000000"/>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="InputKeyBorder"
                                    CornerRadius="4"
                                    Padding="4,4,4,4"
                                    Margin="0,0,10,0">
                                <Border.Background>
                                    <SolidColorBrush Color="#22FFFFFF"/>
                                </Border.Background>
                                <Grid>
                                    <Image x:Name="InputKeyText"
                                           Source="Textures/F.PNG"
                                           Width="40" Height="40"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                    <Image x:Name="InputGamepadIcon"
                                           Source="Textures/A.PNG"
                                           Width="40" Height="40"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                            <TextBlock x:Name="InteractText"
                                       Text="Interactuar"
                                       FontSize="22"
                                       FontFamily="Arial"
                                       VerticalAlignment="Center">
                                <TextBlock.Foreground>
                                    <SolidColorBrush Color="#FFFFFFFF"/>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Canvas>

            <!-- Hints de controles -->
            <Grid VerticalAlignment="Bottom"
                  HorizontalAlignment="Center"
                  Margin="0,0,0,40"
                  Width="600">
                <Border x:Name="ControlsHintPanel"
                        CornerRadius="8"
                        Padding="12,8,12,8"
                        HorizontalAlignment="Center"
                        Visibility="Collapsed">
                    <Border.Background>
                        <SolidColorBrush Color="#AA000000"/>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="200,0,0,0">

                        <StackPanel x:Name="HintSlot1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,16,0"
                                    Visibility="Collapsed">
                            <Grid Margin="0,0,6,0">
                                <Image x:Name="HintImg_Caminar"         Source="Textures/Caminar.PNG"         Width="150" Height="150" Visibility="Collapsed"/>
                                <Image x:Name="HintImg_AtaqueNormal"    Source="Textures/AtaqueNormal.PNG"    Width="150" Height="150" Visibility="Collapsed"/>
                                <Image x:Name="HintImg_AtaqueFuerte"    Source="Textures/AtaqueFuerte.PNG"    Width="150" Height="150" Visibility="Collapsed"/>
                                <Image x:Name="HintImg_Correr"          Source="Textures/Correr.PNG"          Width="150" Height="150" Visibility="Collapsed"/>
                                <Image x:Name="HintImg_CambiarMascaras" Source="Textures/CanviarMascaras.PNG" Width="150" Height="150" Visibility="Collapsed"/>
                                <Image x:Name="HintImg_Health"          Source="Textures/Health.PNG"          Width="150" Height="150" Visibility="Collapsed"/>
                                <Image x:Name="HintImg_Berserk"         Source="Textures/Berserk.PNG"         Width="150" Height="150" Visibility="Collapsed"/>
                            </Grid>
                            <Grid>
                                <Image x:Name="HintKey_WASD"  Source="Textures/wasd.PNG"  Width="120" Height="120" Visibility="Collapsed"/>
                                <Image x:Name="HintKey_E"     Source="Textures/E.PNG"     Width="120" Height="120" Visibility="Collapsed"/>
                                <Image x:Name="HintKey_Q"     Source="Textures/Q.PNG"     Width="120" Height="120" Visibility="Collapsed"/>
                                <Image x:Name="HintKey_Ctrl"  Source="Textures/Ctrl.PNG"  Width="120" Height="120" Visibility="Collapsed"/>
                                <Image x:Name="HintKey_Shift" Source="Textures/Shift.PNG" Width="120" Height="120" Visibility="Collapsed"/>
                                <Image x:Name="HintKey_R"     Source="Textures/R.PNG"     Width="120" Height="120" Visibility="Collapsed"/>
                                <Image x:Name="HintKey_F"     Source="Textures/F.PNG"     Width="120" Height="120" Visibility="Collapsed"/>
                                <Image x:Name="HintKey_8"     Source="Textures/8.PNG"     Width="120" Height="120" Visibility="Collapsed"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="HintSlot2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Visibility="Collapsed">
                            <Grid Margin="0,0,6,0">
                                <Image x:Name="HintImg2_Roll"         Source="Textures/Roll.PNG"         Width="150" Height="150" Visibility="Collapsed"/>
                                <Image x:Name="HintImg2_AtaqueNormal" Source="Textures/AtaqueNormal.PNG" Width="150" Height="150" Visibility="Collapsed"/>
                            </Grid>
                            <Grid>
                                <Image x:Name="HintKey2_Ctrl" Source="Textures/Ctrl.PNG" Width="120" Height="120" Visibility="Collapsed"/>
                                <Image x:Name="HintKey2_E"    Source="Textures/E.PNG"    Width="120" Height="120" Visibility="Collapsed"/>
                            </Grid>
                        </StackPanel>

                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
    </Viewbox>

</Grid>