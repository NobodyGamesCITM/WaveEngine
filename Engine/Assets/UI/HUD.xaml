    <Grid x:Name="LayoutRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d"
    xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
    d:DesignWidth="1920" d:DesignHeight="1080">

        <Grid.RowDefinitions>
            <RowDefinition Height="298*"/>
            <RowDefinition Height="484*"/>
            <RowDefinition Height="298*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200*"/>
            <ColumnDefinition Width="746*"/>
            <ColumnDefinition Width="334*"/>
        </Grid.ColumnDefinitions>

        <!-- Fondo transparente (sin background visible, HUD overlay) -->
        <Grid.Background>
            <SolidColorBrush Color="#00000000"/>
        </Grid.Background>

        <!-- HealthBar: columna izquierda -->
        <Viewbox x:Name="HealtBar_Viewport" Grid.Row="0" Grid.Column="0" Stretch="Uniform">
            <Grid Width="50" Height="68" Margin="0,6,50,26">
                <Grid VerticalAlignment="Bottom" Width="28" Margin="11,0" Height="68">
                    <Rectangle x:Name="HealthFill" Width="28" Height="68" VerticalAlignment="Bottom">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                <GradientStop Offset="0" Color="#FF56FF00"/>
                                <GradientStop Offset="1" Color="#FF288B00"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                        <Rectangle.OpacityMask>
                            <ImageBrush ImageSource="HealthBar_Interior.png"
                                        Stretch="Fill"
                                        AlignmentY="Bottom"
                                        ViewportUnits="Absolute"
                                        Viewport="0,0,28,68"/>
                        </Rectangle.OpacityMask>
                    </Rectangle>
                </Grid>
                <Image x:Name="HealthBar_Image" Source="Health_Bar.png" Margin="11,0"/>
            </Grid>
        </Viewbox>

        <!-- Imagen del jugador: columna central -->
        <Viewbox x:Name="PlayerImage_Viewport" Stretch="Uniform" Grid.Row="0" Grid.Column="1">
            <Image x:Name="mask" Width="100" Height="100" Source="HUD_Player.png"/>
        </Viewbox>

        <!-- StaminaBar: columna derecha -->
        <Viewbox x:Name="StaminaBar_Viewport" Grid.Row="0" Grid.Column="2" Stretch="Uniform">
            <Grid Width="50" Height="68" Margin="50,6,0,26" RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <ScaleTransform ScaleX="-1"/>
                </Grid.RenderTransform>
                <Grid Width="50" VerticalAlignment="Bottom" Margin="11,0,-11,0" Height="68">
                    <Rectangle x:Name="StaminaFill" Height="68" Width="28"
                            VerticalAlignment="Bottom" Margin="1,0,21,0">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                <GradientStop Offset="0" Color="#FF00FFFD"/>
                                <GradientStop Offset="1" Color="#FF0BA9B8"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                        <Rectangle.OpacityMask>
                            <ImageBrush ImageSource="HealthBar_Interior.png"
                                        Stretch="Fill"
                                        AlignmentY="Bottom"
                                        ViewportUnits="Absolute"
                                        Viewport="0,0,28,68"/>
                        </Rectangle.OpacityMask>
                    </Rectangle>
                </Grid>
                <Image x:Name="StaminaBar_Image" Source="Health_Bar.png" Margin="12,0,10,0"/>
            </Grid>
        </Viewbox>

    </Grid>
