    <!--
    ═══════════════════════════════════════════════════════════════════════════
    MissionGrid — contador de estatuas destruidas
    ═══════════════════════════════════════════════════════════════════════════

    Comportamiento:
      · Empieza oculto (Visibility="Collapsed" en MissionViewBox).
      · Lua llama a HUD_RefreshStatuesDestroyed() cuando TotalStatuesToDestroy > 0.
      · Al recoger un coleccionable: MissionExpand + MissionCountBump → visible 3 s
        → MissionCollapse → queda encogido/tenue (solo se ve "N/Total").

    Storyboards:
      MissionExpand   — ScaleX 0.55→1, ScaleY 0.7→1, Opacity 0.35→1  (0.35 s)
      MissionCollapse — ScaleX 1→0.55, ScaleY 1→0.7,  Opacity 1→0.35 (0.5 s)
      MissionCountBump— ScaleX 1.15→1, ScaleY 1.15→1                  (0.4 s)

    RenderTransformOrigin="1,0.5" ancla desde la derecha, así el número
    queda visible aunque el texto de la izquierda desaparezca al colapsar.
    ═══════════════════════════════════════════════════════════════════════════
    -->
    <Grid x:Name="MissionGrid">
        <Grid.Resources>

            <!-- ── Expand: aparece tras recoger un coleccionable ── -->
            <Storyboard x:Name="MissionExpand">
                <DoubleAnimation
                    Storyboard.TargetName="MissionScaleTransform"
                    Storyboard.TargetProperty="ScaleX"
                    From="0.55" To="1.0"
                    Duration="0:0:0.35">
                    <DoubleAnimation.EasingFunction>
                        <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    Storyboard.TargetName="MissionScaleTransform"
                    Storyboard.TargetProperty="ScaleY"
                    From="0.7" To="1.0"
                    Duration="0:0:0.35">
                    <DoubleAnimation.EasingFunction>
                        <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    Storyboard.TargetName="TextViewBox"
                    Storyboard.TargetProperty="Opacity"
                    From="0.35" To="1.0"
                    Duration="0:0:0.3"/>
            </Storyboard>

            <!-- ── Collapse: se contrae tras 3 s, solo queda el número tenue ── -->
            <Storyboard x:Name="MissionCollapse">
                <DoubleAnimation
                    Storyboard.TargetName="MissionScaleTransform"
                    Storyboard.TargetProperty="ScaleX"
                    To="0.55"
                    Duration="0:0:0.5">
                    <DoubleAnimation.EasingFunction>
                        <QuadraticEase EasingMode="EaseIn"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    Storyboard.TargetName="MissionScaleTransform"
                    Storyboard.TargetProperty="ScaleY"
                    To="0.7"
                    Duration="0:0:0.5">
                    <DoubleAnimation.EasingFunction>
                        <QuadraticEase EasingMode="EaseIn"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    Storyboard.TargetName="TextViewBox"
                    Storyboard.TargetProperty="Opacity"
                    To="0.35"
                    Duration="0:0:0.5">
                    <DoubleAnimation.EasingFunction>
                        <QuadraticEase EasingMode="EaseIn"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <!-- ── CountBump: rebote elástico del número al actualizarse ── -->
            <Storyboard x:Name="MissionCountBump">
                <DoubleAnimation
                    Storyboard.TargetName="MissionScaleTransform"
                    Storyboard.TargetProperty="ScaleX"
                    From="1.18" To="1.0"
                    Duration="0:0:0.45">
                    <DoubleAnimation.EasingFunction>
                        <ElasticEase EasingMode="EaseOut" Oscillations="2" Springiness="5"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    Storyboard.TargetName="MissionScaleTransform"
                    Storyboard.TargetProperty="ScaleY"
                    From="1.18" To="1.0"
                    Duration="0:0:0.45">
                    <DoubleAnimation.EasingFunction>
                        <ElasticEase EasingMode="EaseOut" Oscillations="2" Springiness="5"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1599*"/>
            <ColumnDefinition Width="288*"/>
            <ColumnDefinition Width="33*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="194*"/>
            <RowDefinition Height="68*"/>
            <RowDefinition Height="818*"/>
        </Grid.RowDefinitions>

        <!-- Fondo decorativo del panel de misión -->
        <Viewbox Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="2">
            <Path x:Name="MissionBackground" Stretch="Fill" Height="100" Width="470" StrokeThickness="0" StrokeDashCap="Triangle" StrokeDashOffset="7" StrokeEndLineCap="Triangle" StrokeStartLineCap="Triangle" StrokeLineJoin="Round" StrokeMiterLimit="19">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure IsClosed="True" StartPoint="0.45,0">
                            <LineSegment Point="470,0" IsStroked="False"/>
                            <LineSegment Point="470,100" IsStroked="False"/>
                            <LineSegment Point="0,100" IsStroked="False"/>
                            <ArcSegment/>
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
                <Path.Fill>
                    <SolidColorBrush Color="#FFF4F4F5" Opacity="0.194"/>
                </Path.Fill>
            </Path>
        </Viewbox>
        <Viewbox x:Name="MissionViewBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2">
            <TextBlock x:Name="MissionText" TextWrapping="Wrap" Text="Estatuas Destruidas 0/3" FontFamily="Arial" TextAlignment="Center"/>
        </Viewbox>

        <!--
            MissionViewBox — controlado por Lua (Visibility, Storyboards).
            Empieza Collapsed; Lua lo hace Visible cuando TotalStatuesToDestroy > 0.

            RenderTransformOrigin="1,0.5" → el colapso encoge hacia la derecha,
            manteniendo el contador (N/Total) siempre visible en la esquina.
        -->

    </Grid>

</Grid>
