                        <Image Source="Textures/Hermes.PNG" Width="40" Height="40" Opacity="0.6"/>
                    </Viewbox>
                    <Viewbox x:Name="Right_Ares" Visibility="Collapsed" Margin="163,92,14,19">
                        <Image Source="Textures/Ares.PNG" Width="40" Height="40" Opacity="0.6"/>
                    </Viewbox>
                    <Viewbox x:Name="Right_Apolo" Visibility="Collapsed" Margin="163,92,14,19">
                        <Image Source="Textures/Apolo.PNG" Width="40" Height="40" Opacity="0.6"/>
                    </Viewbox>

                </Grid>

