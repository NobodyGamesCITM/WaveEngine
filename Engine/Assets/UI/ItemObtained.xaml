<Grid x:Name="LayoutRoot"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d"
d:DesignWidth="1920" d:DesignHeight="1080">

    <Grid.Background>
        <SolidColorBrush Color="#00000000"/>
    </Grid.Background>

    <Viewbox Stretch="Uniform" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid Width="1920" Height="1080">

            <Grid x:Name="ItemObtainedPanel"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Visibility="Collapsed">
                <Border CornerRadius="10" Padding="60,40,60,40">
                    <Border.Background>
                        <SolidColorBrush Color="#DD000000"/>
                    </Border.Background>
                    <StackPanel Orientation="Vertical"
                                HorizontalAlignment="Center">

                        <Image x:Name="ItemObtainedIcon"
                               Source="Textures/Pocion.PNG"
                               Width="100" Height="100"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                        <TextBlock x:Name="ItemObtainedText"
                                   Text="¡Poción obtenida!"
                                   FontSize="28"
                                   FontFamily="Times New Roman"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,15">
                            <TextBlock.Foreground>
                                <SolidColorBrush Color="#FFFFFFFF"/>
                            </TextBlock.Foreground>
                        </TextBlock>

                        <TextBlock x:Name="ItemObtainedContinue"
                                   Text="[F] Continuar"
                                   FontSize="18"
                                   FontFamily="Arial"
                                   HorizontalAlignment="Center">
                            <TextBlock.Foreground>
                                <SolidColorBrush Color="#FFAAAAAA"/>
                            </TextBlock.Foreground>
                        </TextBlock>

                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
    </Viewbox>

</Grid>