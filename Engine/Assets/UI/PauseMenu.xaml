<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d"
  xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
  xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
  xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
  d:DesignWidth="1280" d:DesignHeight="720">

    <Grid.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="TextButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontFamily" Value="./#ForgottenUncial"/>
                <Setter Property="FontSize" Value="36"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Image x:Name="ArrowL" Source="Textures/Arrow.PNG" Width="30" Height="30" Margin="0,0,15,0" Visibility="Hidden" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TextContent"
                                           Text="{TemplateBinding Content}"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"
                                           Foreground="{TemplateBinding Foreground}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <Image x:Name="ArrowR" Source="Textures/Arrow.PNG" Width="30" Height="30" Margin="15,0,0,0" Visibility="Hidden" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <Image.RenderTransform>
                                        <ScaleTransform ScaleX="-1"/>
                                    </Image.RenderTransform>
                                </Image>
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="ArrowL" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="ArrowR" Property="Visibility" Value="Visible"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="TextContent" Property="Foreground" Value="#88FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Grid.Resources>

    <Grid x:Name="LayoutRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="100*"/>
            <RowDefinition Height="300*"/>
            <RowDefinition Height="120*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50*"/>
            <ColumnDefinition Width="300*"/>
            <ColumnDefinition Width="60*"/>
        </Grid.ColumnDefinitions>
        <Grid.Background>
            <ImageBrush ImageSource="Textures/Menu.PNG"/>
        </Grid.Background>

        <Grid Grid.Column="1" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="200*"/>
                <RowDefinition Height="800*"/>
            </Grid.RowDefinitions>

            <Viewbox x:Name="Pause_Viewbox" Stretch="Uniform" Width="445" Margin="261,2,231,2">
                <Grid Height="80" Width="445">
                    <TextBlock x:Name="Pause_text"
                               TextAlignment="Center"
                               FontSize="65"
                               Width="445"
                               Text="PAUSE" Margin="3,0,-3,-2" FontFamily="./#ForgottenUncial">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                <GradientStop Offset="0" Color="#FFFFFFFF"/>
                                <GradientStop Offset="1" Color="#FFFFFFFF"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                </Grid>
            </Viewbox>

            <Viewbox x:Name="Buttons_ViewBox" Grid.Row="1" Stretch="Uniform">
                <Grid Height="460" Width="768">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="100*"/>
                        <RowDefinition Height="100*"/>
                        <RowDefinition Height="30*"/>
                        <RowDefinition Height="100*"/>
                        <RowDefinition Height="30*"/>
                        <RowDefinition Height="100*"/>
                    </Grid.RowDefinitions>

                    <Button x:Name="ResumeButton"
                            Grid.Row="1"
                            Margin="60,0,0,0"
                            Style="{StaticResource TextButtonStyle}"
                            Command="{Binding Path=Commands[ResumeButton]}"
                            Content="RESUME">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="Loaded">
                                <noesis:SetFocusAction/>
                            </i:EventTrigger>
                            <i:EventTrigger EventName="MouseEnter">
                                <noesis:SetFocusAction/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>

                    <Button x:Name="SettingsButton"
                            Grid.Row="3"
                            Margin="60,0,0,0"
                            Style="{StaticResource TextButtonStyle}"
                            Command="{Binding Commands[SettingsButton]}"
                            Content="SETTINGS">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="MouseEnter">
                                <noesis:SetFocusAction/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>

                    <Button x:Name="BackToMenuButton"
                            Grid.Row="5"
                            Margin="60,0,0,0"
                            Style="{StaticResource TextButtonStyle}"
                            Content="BACK TO MENU"
                            Command="{Binding Path=Commands[BackToMenuButton]}">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="MouseEnter">
                                <noesis:SetFocusAction/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>
                </Grid>
            </Viewbox>
        </Grid>
    </Grid>

</Grid>
