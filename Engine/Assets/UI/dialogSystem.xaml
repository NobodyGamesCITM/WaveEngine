<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d"
  xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
  xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
  d:DesignWidth="1280" d:DesignHeight="720">

    <Grid.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Storyboard x:Key="DialogEnter">
                <DoubleAnimationUsingKeyFrames
                    Storyboard.TargetName="DialogBox"
                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)">
                    <EasingDoubleKeyFrame KeyTime="0" Value="80"/>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.35" Value="0">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <CircleEase EasingMode="EaseOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames
                    Storyboard.TargetName="DialogBox"
                    Storyboard.TargetProperty="Opacity">
                    <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="1"/>
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>

            <Storyboard x:Key="DialogExit">
                <DoubleAnimationUsingKeyFrames
                    Storyboard.TargetName="DialogBox"
                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)">
                    <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="80">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <CircleEase EasingMode="EaseIn"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames
                    Storyboard.TargetName="DialogBox"
                    Storyboard.TargetProperty="Opacity">
                    <EasingDoubleKeyFrame KeyTime="0" Value="1"/>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="0"/>
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>

            <Storyboard x:Key="ContinueBounce" RepeatBehavior="Forever">
                <DoubleAnimationUsingKeyFrames
                    Storyboard.TargetName="ContinueIcon"
                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)">
                    <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.45" Value="5">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.9" Value="0">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>

        </ResourceDictionary>
    </Grid.Resources>

    <Grid.Background>
        <SolidColorBrush Color="Transparent"/>
    </Grid.Background>

    <Viewbox Stretch="Uniform"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

        <Grid x:Name="LayoutRoot" Width="1280" Height="720">

            <Grid x:Name="DialogBox"
                  VerticalAlignment="Bottom"
                  HorizontalAlignment="Stretch"
                  Margin="60,0,60,28"
                  Height="180"
                  Visibility="Collapsed">

                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform Y="0"/>
                    </TransformGroup>
                </Grid.RenderTransform>

                <Border BorderThickness="2" CornerRadius="4">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#FF8B6914"/>
                    </Border.BorderBrush>
                    <Border.Background>
                        <SolidColorBrush Color="#CC0A0A14"/>
                    </Border.Background>

                    <Border BorderThickness="1" CornerRadius="3" Margin="3">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#FF4A3A0A"/>
                        </Border.BorderBrush>

                        <Grid Margin="8,8,12,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" VerticalAlignment="Stretch">
                                <Border BorderThickness="2" CornerRadius="3">
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="#FF8B6914"/>
                                    </Border.BorderBrush>
                                    <Border.Background>
                                        <SolidColorBrush Color="#22FFD97D"/>
                                    </Border.Background>
                                </Border>
                                <Image x:Name="Portrait"
                                       Stretch="UniformToFill"
                                       Source="Textures/Portrait_Placeholder.png"
                                       Margin="2"/>
                            </Grid>

                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        HorizontalAlignment="Left"
                                        CornerRadius="2,2,0,0"
                                        Padding="10,4,10,4"
                                        Margin="0,0,0,6">
                                    <Border.Background>
                                        <SolidColorBrush Color="#DD1A120A"/>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="#FF8B6914"/>
                                    </Border.BorderBrush>
                                    <Border.BorderThickness>0,0,0,1</Border.BorderThickness>
                                    <TextBlock x:Name="CharacterName"
                                               Text=""
                                               FontSize="14"
                                               FontWeight="Bold"
                                               FontFamily="Arial">
                                        <TextBlock.Foreground>
                                            <SolidColorBrush Color="#FFFFD97D"/>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                </Border>

                                <TextBlock x:Name="DialogText"
                                           Grid.Row="1"
                                           Text=""
                                           FontSize="13"
                                           FontFamily="Arial"
                                           TextWrapping="Wrap"
                                           LineHeight="20"
                                           VerticalAlignment="Top"
                                           Margin="2,0,0,4">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush Color="#FFE8DCC8"/>
                                    </TextBlock.Foreground>
                                </TextBlock>

                                <TextBlock x:Name="ContinueIcon"
                                           Grid.Row="2"
                                           Text="▼"
                                           FontSize="11"
                                           FontFamily="Arial"
                                           HorizontalAlignment="Right"
                                           Margin="0,0,4,2"
                                           Visibility="Collapsed">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush Color="#FFFFD97D"/>
                                    </TextBlock.Foreground>
                                    <TextBlock.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform/>
                                            <SkewTransform/>
                                            <RotateTransform/>
                                            <TranslateTransform/>
                                        </TransformGroup>
                                    </TextBlock.RenderTransform>
                                    <TextBlock.Triggers>
                                        <EventTrigger RoutedEvent="TextBlock.Loaded">
                                            <BeginStoryboard Storyboard="{StaticResource ContinueBounce}"/>
                                        </EventTrigger>
                                    </TextBlock.Triggers>
                                </TextBlock>

                            </Grid>
                        </Grid>
                    </Border>
                </Border>

            </Grid>

        </Grid>
    </Viewbox>

</Grid>
