<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d"
  xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
  xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
  d:DesignWidth="1280" d:DesignHeight="720">

    <Grid.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Storyboard x:Key="ContinueBounce" RepeatBehavior="Forever">
                <DoubleAnimationUsingKeyFrames
                    Storyboard.TargetName="ContinueIcon"
                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)">
                    <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.45" Value="5">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.9" Value="0">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>

        </ResourceDictionary>
    </Grid.Resources>

    <Grid.Background>
        <SolidColorBrush Color="Transparent"/>
    </Grid.Background>

    <Viewbox Stretch="Uniform"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

        <Grid x:Name="LayoutRoot" Width="1280" Height="720">

            <!-- Contenedor principal anclado abajo y centrado -->
            <Grid x:Name="DialogBox"
                  VerticalAlignment="Bottom"
                  HorizontalAlignment="Center"
                  Width="900"
                  Height="280"
                  Margin="0,0,0,10"
                  Visibility="Collapsed">

                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform Y="0"/>
                    </TransformGroup>
                </Grid.RenderTransform>

                <!-- Layout: portrait a la izquierda, pergamino+texto a la derecha -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <!-- Portrait -->
                        <ColumnDefinition Width="160"/>
                        <!-- Pergamino con texto -->
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ===== PORTRAIT: sobresale por arriba, anclado abajo ===== -->
                    <Grid Grid.Column="0"
                          Width="150" Height="260"
                          VerticalAlignment="Bottom"
                          HorizontalAlignment="Center">
                        <Border x:Name="Portrait_Telemaco" Visibility="Collapsed">
                            <Image Stretch="Uniform"
                                   Source="Textures/Portrait_Placeholder3.png"
                                   VerticalAlignment="Bottom"/>
                        </Border>
                        <Border x:Name="Portrait_Atenea" Visibility="Collapsed">
                            <Image Stretch="Uniform"
                                   Source="Textures/Portrait_Placeholder.png"
                                   VerticalAlignment="Bottom"/>
                        </Border>
                        <Border x:Name="Portrait_JohnCartel" Visibility="Collapsed">
                            <Image Stretch="Uniform"
                                   Source="Textures/Portrait_Placeholder2.png"
                                   VerticalAlignment="Bottom"/>
                        </Border>
                    </Grid>

                    <!-- ===== PERGAMINO + TEXTO ===== -->
                    <Grid Grid.Column="1" VerticalAlignment="Bottom" Height="160">

                        <!-- Pergamino de fondo -->
                        <Image Source="Textures/CuadroDialogo.PNG"
                               Stretch="Fill"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch"/>

                        <!-- Texto encima del pergamino -->
                        <Grid Margin="75,30,15,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Nombre del personaje -->
                            <TextBlock x:Name="CharacterName"
                                       Grid.Row="0"
                                       Text=""
                                       FontSize="15"
                                       FontWeight="Bold"
                                       FontFamily="Times New Roman"
                                       Margin="0,0,0,5">
                                <TextBlock.Foreground>
                                    <SolidColorBrush Color="#FF5C3300"/>
                                </TextBlock.Foreground>
                            </TextBlock>

                            <!-- Texto del diálogo -->
                            <TextBlock x:Name="DialogText"
                                       Grid.Row="1"
                                       Text=""
                                       FontSize="13"
                                       FontFamily="Times New Roman"
                                       FontStyle="Italic"
                                       TextWrapping="Wrap"
                                       LineHeight="20"
                                       VerticalAlignment="Top">
                                <TextBlock.Foreground>
                                    <SolidColorBrush Color="#FF3D2200"/>
                                </TextBlock.Foreground>
                            </TextBlock>

                            <!-- Icono continuar -->
                            <TextBlock x:Name="ContinueIcon"
                                       Grid.Row="2"
                                       Text="▼"
                                       FontSize="11"
                                       FontFamily="Times New Roman"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,4,0"
                                       Visibility="Collapsed">
                                <TextBlock.Foreground>
                                    <SolidColorBrush Color="#FF7A4A00"/>
                                </TextBlock.Foreground>
                                <TextBlock.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform/>
                                        <SkewTransform/>
                                        <RotateTransform/>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </TextBlock.RenderTransform>
                                <TextBlock.Triggers>
                                    <EventTrigger RoutedEvent="TextBlock.Loaded">
                                        <BeginStoryboard Storyboard="{StaticResource ContinueBounce}"/>
                                    </EventTrigger>
                                </TextBlock.Triggers>
                            </TextBlock>

                        </Grid>
                    </Grid>

                </Grid>

            </Grid>

        </Grid>
    </Viewbox>

</Grid>
