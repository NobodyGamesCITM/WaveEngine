<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d"
  xmlns:noesis="clr-namespace:NoesisGUIExtensions;assembly=Noesis.GUI.Extensions"
  d:DesignWidth="1280" d:DesignHeight="720">

    <Grid.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Storyboard x:Key="ContinueBounce" RepeatBehavior="Forever">
                <DoubleAnimationUsingKeyFrames
                    Storyboard.TargetName="ContinueIcon"
                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)">
                    <EasingDoubleKeyFrame KeyTime="0" Value="0"/>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.45" Value="5">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                    <EasingDoubleKeyFrame KeyTime="0:0:0.9" Value="0">
                        <EasingDoubleKeyFrame.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </EasingDoubleKeyFrame.EasingFunction>
                    </EasingDoubleKeyFrame>
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>

        </ResourceDictionary>
    </Grid.Resources>

    <Grid.Background>
        <SolidColorBrush Color="Transparent"/>
    </Grid.Background>

    <Viewbox Stretch="Uniform"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

        <Grid x:Name="LayoutRoot" Width="1280" Height="720">

            <!-- DialogBox alto para que el portrait sobresalga sin cortarse -->
            <Grid x:Name="DialogBox"
                  VerticalAlignment="Bottom"
                  HorizontalAlignment="Stretch"
                  Height="380"
                  Visibility="Collapsed">

                <!-- CAPA 1: Pergamino + texto, anclado abajo, dejando hueco a la izquierda -->
                <Grid VerticalAlignment="Bottom"
                      HorizontalAlignment="Stretch"
                      Height="160"
                      Margin="180,0,20,10">

                    <Image Source="Textures/CuadroDialogo.PNG"
                           Stretch="Fill"/>

                    <!-- Nombre: pestaña pegada al borde superior del pergamino -->
                    <Border HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="40,-30,0,0"
                            Padding="14,5,14,5"
                            CornerRadius="3">
                        <Border.Background>
                            <SolidColorBrush Color="#CC5C3300"/>
                        </Border.Background>
                        <TextBlock x:Name="CharacterName"
                                   Text=""
                                   FontSize="17"
                                   FontWeight="Bold"
                                   FontFamily="Times New Roman">
                            <TextBlock.Foreground>
                                <SolidColorBrush Color="#FFFDF0D0"/>
                            </TextBlock.Foreground>
                        </TextBlock>
                    </Border>

                    <!-- Texto diálogo -->
                    <TextBlock x:Name="DialogText"
                               Text=""
                               FontSize="14"
                               FontFamily="Georgia"
                               FontStyle="Italic"
                               TextWrapping="Wrap"
                               LineHeight="22"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Stretch"
                               Margin="50,25,50,20">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="#FF3D2200"/>
                        </TextBlock.Foreground>
                    </TextBlock>

                    <!-- Continuar: esquina inferior derecha -->
                    <TextBlock x:Name="ContinueIcon"
                               Text="▼"
                               FontSize="16"
                               FontFamily="Times New Roman"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Bottom"
                               Margin="0,0,30,12"
                               Visibility="Collapsed">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="#FF7A4A00"/>
                        </TextBlock.Foreground>
                        <TextBlock.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </TextBlock.RenderTransform>
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="TextBlock.Loaded">
                                <BeginStoryboard Storyboard="{StaticResource ContinueBounce}"/>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>

                </Grid>

                <!-- CAPA 2: Portrait sin Border, libre de crecer, anclado abajo-izquierda -->
                <Image x:Name="Portrait_Telemaco"
                       Source="Textures/Telemaco.png"
                       Stretch="Uniform"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Bottom"
                       Width="220"
                       Margin="20,0,0,10"
                       Visibility="Collapsed"/>

                <Image x:Name="Portrait_Atenea"
                       Source="Textures/Atenea.png"
                       Stretch="Uniform"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Bottom"
                       Width="220"
                       Margin="20,0,0,10"
                       Visibility="Collapsed"/>

                <Image x:Name="Portrait_JohnCartel"
                       Source="Textures/Portrait_Placeholder2.png"
                       Stretch="Uniform"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Bottom"
                       Width="220"
                       Margin="20,0,0,10"
                       Visibility="Collapsed"/>

            </Grid>

        </Grid>
    </Viewbox>

</Grid>